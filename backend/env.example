APP_NAME=V蓹t蓹nda艧 m眉raci蓹tl蓹rinin elektron qeydiyyat谋
ENV=dev

# SQLite default (good for local dev)
DATABASE_URL=sqlite:///./app.db

# Auth (change in prod)
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS
# Use "*" for local dev; in prod, set exact origins, comma-separated
CORS_ALLOW_ORIGINS=*

# Optional: create initial admin if DB is empty (first run convenience)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_FULL_NAME=System Admin

# Startup: h蓹r i艧蓹 d眉艧m蓹d蓹 env-d蓹ki superadmin Users-d蓹 yarad谋l谋r v蓹 ya yenil蓹nir (艧ifr蓹 + admin bayraqlar谋).
# Parol SHA-256 il蓹 saxlan谋r. 茝vv蓹lc蓹 BOOTSTRAP_SUPERADMIN_PASSWORD, bo艧dursa BOOTSTRAP_ADMIN_PASSWORD.
BOOTSTRAP_SUPERADMIN_ENABLED=true
BOOTSTRAP_SUPERADMIN_USERNAME=superadmin
BOOTSTRAP_SUPERADMIN_PASSWORD=
BOOTSTRAP_SUPERADMIN_SURNAME=Super
BOOTSTRAP_SUPERADMIN_NAME=Admin

