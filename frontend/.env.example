# API ünvanı (Vite build/dev zamanı oxunur)
#
# 1) Frontend və backend EYNİ kompüterdə (local):
#    VITE_API_URL=/api/v1
#    (Vite proxy backend-ə yönləndirir)
#
# 2) Frontend BAŞQA kompüterdə, backend SİZİN kompüterdə:
#    Backend olan kompüterin IP-ni yazın, məsələn:
#    VITE_API_URL=http://192.168.1.100:8000/api/v1
#    (192.168.1.100 əvəzinə öz IP-nizi yazın)

VITE_API_URL=/api/v1

# Vite dev proxy hədəfi (default: http://localhost:8002; backend 0.0.0.0:8002-də dinləyir).
# `npm run dev` əvvəl bu ünvanda /health gözlənir.
# VITE_DEV_PROXY_TARGET=http://localhost:8002

# Backend olmadan yalnız UI üçün: npm run dev:vite-only

# Superadmin bootstrap backend `backend/env` faylında: BOOTSTRAP_SUPERADMIN_*
