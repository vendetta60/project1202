{
  "name": "project1202",
  "private": true,
  "scripts": {
    "predev": "powershell -ExecutionPolicy Bypass -NoProfile -File scripts/kill-dev-ports.ps1",
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && .venv310\\Scripts\\python.exe -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8002",
    "dev:frontend": "cd frontend && npm run dev",
    "stop": "powershell -ExecutionPolicy Bypass -NoProfile -File scripts/kill-dev-ports.ps1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
